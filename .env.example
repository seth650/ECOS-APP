# Client (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: full origin for local API (e.g. http://localhost:3000 when using `vercel dev`). Leave empty on Vercel production.
VITE_API_BASE_URL=

# Server-only (Vercel Environment Variables — never expose to client)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Calculator $49/mo (STRIPE_PRICE_ID)
STRIPE_PRICE_ID=price_...
# Estimator $149/mo (prefer STRIPE_ESTIMATOR_PRICE_ID; STRIPE_CALCULATOR_PRICE_ID still accepted as legacy alias)
STRIPE_ESTIMATOR_PRICE_ID=price_...
# STRIPE_CALCULATOR_PRICE_ID=price_...
# Contractor pricing application notify (default seth@dynastyepoxy.com)
CONTRACTOR_PRICING_NOTIFY_TO=seth@dynastyepoxy.com
SUPABASE_SERVICE_ROLE_KEY=
# Vercel Cron auth (set in Vercel → Settings → Environment Variables as CRON_SECRET)
CRON_SECRET=
# Public site URL for Stripe redirects (your production or preview URL)
PUBLIC_SITE_URL=https://your-deployment.vercel.app

# From address for material PO emails (must be a Resend-verified domain)
MATERIAL_PO_EMAIL_FROM=ECOS Orders <Rufus@epoxyquoting.com>

# Resend (grace-period emails; reuse PO sender domain)
RESEND_API_KEY=
GRACE_EMAIL_FROM=Rufus <Rufus@epoxyquoting.com>
